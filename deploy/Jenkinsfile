pipeline {
    agent any
    triggers {
        // This ONLY runs the pipeline if a new commit ID is found
        pollSCM('*/5 * * * *') 
    }
    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'prod'], description: 'Target environment')
        string(name: 'IMAGE_TAG', description: 'Image tag to deploy, e.g. v1.2.0')
    }

    environment {
        IMAGE_NAME = 'mayur21486/hello-world-app'   // <-- same as CI
    }

    stages {
        stage('Render manifests') {
            steps {
                withCredentials([file(credentialsId: 'k8s-kubeconfig-id', variable: 'KUBECONFIG')]) {
                    sh """#!/bin/bash
                        set -a; source Deployment/env/${params.ENVIRONMENT}.env; set +a
                        export IMAGE="${env.IMAGE_NAME}:${params.IMAGE_TAG}"
                        mkdir -p rendered
                        for f in Deployment/0*.yaml; do
                            envsubst '\${IMAGE} \${REPLICAS}' < "\$f" > "rendered/\$(basename "\$f")"
                        done
                    """
                }
            }
        }

        stage('kubectl diff') {
            steps {
                withCredentials([file(credentialsId: 'k8s-kubeconfig-id', variable: 'KUBECONFIG')]) {
                    sh 'kubectl diff -f rendered/ || true'   // diff exits non-zero on any change; don'\''t fail the build on it
                }
            }
        }

        stage('Approval') {
            when { expression { params.ENVIRONMENT != 'dev' } }
            steps {
                input message: "Deploy ${params.IMAGE_TAG} to ${params.ENVIRONMENT}?"
            }
        }

        stage('Apply') {
            steps {
                withCredentials([file(credentialsId: 'k8s-kubeconfig-id', variable: 'KUBECONFIG')]) {
                    sh """#!/bin/bash
                        kubectl apply -f rendered/
                        kubectl rollout status deployment/hello-world -n hello-world --timeout=120s
                    """
                }
            }
        }

        stage('Show ingress') {
            steps {
                withCredentials([file(credentialsId: 'k8s-kubeconfig-id', variable: 'KUBECONFIG')]) {
                    sh 'kubectl get ingress -n hello-world'
                }
            }
        }
    }

    post {
        always { cleanWs() }
    }
}